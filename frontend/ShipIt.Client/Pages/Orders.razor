@page "/orders"
@using System.Globalization
@inject OrdersApiClient ApiClient
@inject NavigationManager Navigation

<PageTitle>Заказы | ShipIt</PageTitle>

<div class="page-heading">
    <div>
        <h1>Заказы</h1>
        <p class="text-muted">Все заказы на доставку. Сначала показаны новые.</p>
    </div>
    <a class="btn btn-primary" href="orders/create">Создать заказ</a>
</div>

@if (_isLoading)
{
    <p>Загрузка заказов...</p>
}
else if (_error is not null)
{
    <div class="alert alert-danger" role="alert">@_error</div>
    <button class="btn btn-outline-primary" @onclick="LoadOrdersAsync">Повторить</button>
}
else if (_orders.Count == 0)
{
    <div class="empty-state">
        <h2>Заказов пока нет</h2>
        <p>Создайте первый заказ на доставку.</p>
        <a class="btn btn-primary" href="orders/create">Создать заказ</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle orders-table">
            <thead>
                <tr>
                    <th>Номер заказа</th>
                    <th>Отправитель</th>
                    <th>Получатель</th>
                    <th>Вес</th>
                    <th>Дата получения</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var order in _orders)
            {
                <tr class="order-row" tabindex="0" @onclick="() => OpenOrder(order.Id)"
                    @onkeydown="args => HandleKeyDown(args, order.Id)">
                    <td><strong>@order.OrderNumber</strong></td>
                    <td>@order.SenderCity<br /><span class="text-muted">@order.SenderAddress</span></td>
                    <td>@order.RecipientCity<br /><span class="text-muted">@order.RecipientAddress</span></td>
                    <td class="order-weight">@order.CargoWeight.ToString("0.###")&nbsp;кг</td>
                    <td class="order-date">@order.PickupDate.ToString("dd MMM yyyy", RussianCulture)</td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="pagination-controls">
        <button class="btn btn-outline-primary" @onclick="PreviousPageAsync" disabled="@(_pageNumber <= 1)">
            Назад
        </button>
        <span class="text-muted">Страница @_pageNumber из @_totalPages</span>
        <button class="btn btn-outline-primary" @onclick="NextPageAsync" disabled="@(_pageNumber >= _totalPages)">
            Вперёд
        </button>
    </div>
}

@code {
    private const int PageSize = 20;
    private IReadOnlyList<OrderListItem> _orders = [];
    private static readonly CultureInfo RussianCulture = CultureInfo.GetCultureInfo("ru-RU");
    private bool _isLoading = true;
    private string? _error;
    private int _pageNumber = 1;
    private int _totalPages;

    protected override Task OnInitializedAsync() => LoadOrdersAsync();

    private async Task LoadOrdersAsync()
    {
        _isLoading = true;
        _error = null;
        try
        {
            var page = await ApiClient.GetOrdersAsync(_pageNumber, PageSize);
            _orders = page.Items;
            _pageNumber = page.PageNumber;
            _totalPages = page.TotalPages;
        }
        catch (Exception exception)
        {
            _error = $"Не удалось загрузить заказы. {exception.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OpenOrder(Guid id) => Navigation.NavigateTo($"/orders/{id}");

    private async Task PreviousPageAsync()
    {
        if (_pageNumber <= 1)
        {
            return;
        }

        _pageNumber--;
        await LoadOrdersAsync();
    }

    private async Task NextPageAsync()
    {
        if (_pageNumber >= _totalPages)
        {
            return;
        }

        _pageNumber++;
        await LoadOrdersAsync();
    }

    private void HandleKeyDown(KeyboardEventArgs args, Guid id)
    {
        if (args.Key is "Enter" or " ")
        {
            OpenOrder(id);
        }
    }
}
